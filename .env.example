# # .env.example — copy this file to .env and fill in your real API keys.
# # Never commit .env to version control.

# # OpenAI API key
# # Get yours at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here

# # (Optional) Override the OpenAI model used for summarisation
# LLM_MODEL=gpt-4o-mini

# # (Optional) Maximum tokens in the LLM response
# LLM_MAX_TOKENS=1024

# # (Optional) Number of search results to fetch
# SEARCH_MAX_RESULTS=5

# # (Optional) Path to the SQLite database file
# DB_PATH=research.db
